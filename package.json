{
  "name": "obsidian-invoke",
  "version": "0.1.0",
  "description": "API client plugin for Obsidian with .ivk file format",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "api", "rest", "http", "invoke"],
  "author": "Doston Kamilov",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "tslib": "2.8.1",
    "typescript": "5.7.2"
  }
}
