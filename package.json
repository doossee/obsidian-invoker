{
  "name": "obsidian-invoker",
  "version": "0.1.0",
  "description": "A Bruno-like API client for Obsidian. Create, run, and document HTTP requests with the .ivk file format.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"styles.css\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"styles.css\" \"*.md\"",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "api",
    "api-client",
    "rest",
    "rest-client",
    "http",
    "http-client",
    "postman",
    "bruno",
    "invoker"
  ],
  "author": {
    "name": "Doston Kamilov",
    "url": "https://github.com/doossee"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doossee/obsidian-invoker.git"
  },
  "bugs": {
    "url": "https://github.com/doossee/obsidian-invoker/issues"
  },
  "homepage": "https://github.com/doossee/obsidian-invoker#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "obsidian": "latest",
    "prettier": "^3.4.2",
    "tslib": "2.8.1",
    "typescript": "5.7.2"
  }
}
